# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — file is created automatically)
DATABASE_URL="file:./dev.db"

# Postgres migration (uncomment and fill when switching)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tattoo_site?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_generate_a_random_32_char_string"
NEXTAUTH_URL="http://localhost:3000"

# ── Resend (email service) ────────────────────────────────────────────────────
RESEND_API_KEY="re_PLACEHOLDER_replace_with_your_key"
RESEND_FROM_EMAIL="newsletter@yourdomain.de"
RESEND_REPLY_TO="hello@yourdomain.de"

# ── hCaptcha ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_HCAPTCHA_SITE_KEY="10000000-ffff-ffff-ffff-000000000001"
HCAPTCHA_SECRET_KEY="0x0000000000000000000000000000000000000000"

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Vira Linevych"

# ── Admin seed ───────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="changeme123"
